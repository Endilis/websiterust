{
   "action": {
      "default_icon": "icons/rustinfo_256.png",
      "default_title": "LOGIN to rustInfo.online"
   },
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ {
      "js": [ "addon.js" ],
      "matches": [ "https://companion-rust.facepunch.com/*" ]
   } ],
   "icons": {
      "128": "icons/rustinfo_128.png",
      "16": "icons/rustinfo_16.png",
      "256": "icons/rustinfo_256.png",
      "32": "icons/rustinfo_32.png",
      "48": "icons/rustinfo_48.png",
      "64": "icons/rustinfo_64.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "RustInfo Bot",
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.0",
   "web_accessible_resources": [ {
      "matches": [ "https://companion-rust.facepunch.com/*" ],
      "resources": [ "worker.js" ]
   } ]
}
